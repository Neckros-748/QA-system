{
  "generation": {
    "max_new_tokens": 256,
    "temperature": 0.3,
    "do_sample": true,
    "repetition_penalty": 1.1,
    "top_p": null,
    "top_k": null
  },
  "model": {
    "base_name": "Vikhrmodels/Vikhr-Llama-3.2-1B-Instruct",
    "adapter_path": "qa_adapter",
    "device": "cpu",
    "use_4bit": false
  },
  "preprocessor": {
    "stop_words": ["это", "то", "так", "вопрос", "ответ"],
    "use_lemmatizer": false
  },
  "retriever": {
    "top_k": 5,
    "embedding_model": "sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2",
    "index_path": "vector_index.faiss"
  },
  "query_builder": {
    "max_context_tokens": 2000,
    "template": "<|user|>\nКонтекст: {context}\n\nВопрос: {question}\n<|end|>\n<|assistant|>\n"
  },
  "postprocessor": {
    "remove_special_tokens": true
  },
  "dialogue_manager": {
    "max_history_turns": 10,
    "max_history_tokens": 2000
  }
}